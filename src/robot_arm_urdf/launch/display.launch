<launch>
  <arg name="gui" default="true" />
  <arg name="rvizconfig" default="$(find-pkg-share robot_arm_urdf)/rviz/urdf.rviz" />

  <node pkg="robot_state_publisher" exec="robot_state_publisher" name="robot_state_publisher">
    <param name="robot_description" value="$(command 'xacro $(find-pkg-share robot_arm_urdf)/urdf/robot_arm_urdf.urdf')"/>
  </node>

  <group if="$(var gui)">
    <node pkg="joint_state_publisher_gui" exec="joint_state_publisher_gui" name="joint_state_publisher_gui" />
  </group>
  <group unless="$(var gui)">
    <node pkg="joint_state_publisher" exec="joint_state_publisher" name="joint_state_publisher" />
  </group>

  <node pkg="rviz2" exec="rviz2" name="rviz2" args="-d $(var rvizconfig)" output="screen" />
</launch>