<launch>
  <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
    <arg name="gz_args" value="-r empty.sdf"/>
  </include>

  <!-- Spawn the robot directly from the URDF file into Ignition Gazebo -->
  <node pkg="ros_gz_sim" exec="create" name="spawn_robot" output="screen"
        args="-file $(find-pkg-share robot_arm_urdf)/urdf/robot_arm_urdf.urdf -name robot_arm_urdf -z 0.1"/>
</launch>